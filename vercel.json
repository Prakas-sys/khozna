{
  "version": 2,
  "name": "admin-dashboard-web",
  "builds": [
    {
      "src": "admin_dashboard_web/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "status": 200, "dest": "/index.html" }
  ]
}
